NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://qsl_user:qsl_password@localhost:5433/qsl_db
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:3000

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Session
SESSION_SECRET=qsl-dev-secret-change-in-production-min-32-chars

# SMS Provider (Eskiz.uz, Playmobile.uz, va boshqalar)
SMS_PROVIDER_URL=
SMS_PROVIDER_TOKEN=

# Email Provider (SMTP, SendGrid, AWS SES, va boshqalar)
EMAIL_PROVIDER_HOST=
EMAIL_PROVIDER_PORT=587
EMAIL_PROVIDER_USER=
EMAIL_PROVIDER_PASSWORD=
EMAIL_FROM=noreply@qashqadaryostartup.uz
